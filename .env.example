# ─────────────────────────────────────────────────────────────────────────────
# GameBuddi — Environment Variables
# Copy this file to .env and fill in real values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have sensible defaults or degrade gracefully.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────

# [OPTIONAL] "development" or "production" — set automatically by Next.js in most cases.
NODE_ENV="development"

# [OPTIONAL] Public-facing URL (no trailing slash).
# Used for email links and Stripe checkout redirects.
# Default: http://localhost:3000
# In production, set to your deployed URL (e.g. https://gamebuddi.com).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database ─────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string.
# Local dev:  postgresql://gamebuddi_user:YOUR_PASSWORD@localhost:5432/gamebuddi
# Railway:    Automatically set by the PostgreSQL plugin — no action needed.
DATABASE_URL=""

# ── Stripe (Payments) ───────────────────────────────────────────────────────

# [REQUIRED] Secret key for server-side Stripe API calls (starts with sk_).
# Get it at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# [REQUIRED] Publishable key for client-side Stripe.js (starts with pk_).
# This is safe to expose in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# [REQUIRED] Each plan needs a Price ID from Stripe (starts with price_).
# Create these in: https://dashboard.stripe.com/products
#
# Weekend Pass — one-time payment, grants 3 days of access.
STRIPE_PRICE_WEEKEND="price_..."
# Weekly Pass — one-time payment, grants 7 days of access.
STRIPE_PRICE_WEEKLY="price_..."
# Monthly Subscription — recurring monthly billing.
STRIPE_PRICE_MONTHLY="price_..."
# Annual Subscription — recurring yearly billing.
STRIPE_PRICE_ANNUAL="price_..."

# [REQUIRED] Webhook signing secret for verifying Stripe events (starts with whsec_).
# Create a webhook at: https://dashboard.stripe.com/webhooks
# Point it to: https://YOUR_DOMAIN/api/webhook
# Events needed: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ──────────────────────────────────────────────────────────

# [OPTIONAL] Resend API key for sending transactional emails.
# If not set, emails are logged to the console (useful for local dev).
# Sign up at: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# [OPTIONAL] The "From" address for outgoing emails.
# Must be a verified sender domain in Resend.
# Default: "GameBuddi <noreply@gamebuddi.com>"
EMAIL_FROM="GameBuddi <noreply@gamebuddi.com>"

# ── Push Notifications (VAPID) ──────────────────────────────────────────────

# [OPTIONAL] VAPID keys for Web Push notifications.
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ── TURN Server (WebRTC) ────────────────────────────────────────────────────

# [OPTIONAL] Improves multiplayer connectivity behind strict NATs/firewalls.
# Without this, free public TURN servers are used as a fallback.
# Get credentials from: https://www.metered.ca/stun-turn or https://www.twilio.com/stun-turn
TURN_SERVER_URL=""
TURN_SERVER_USERNAME=""
TURN_SERVER_CREDENTIAL=""

# ── Cron Jobs ────────────────────────────────────────────────────────────────

# [OPTIONAL] Secret token to authenticate cron requests.
# Pass as: Authorization: Bearer <CRON_SECRET>
# Used by /api/cron/send-rankings — if not set, cron endpoints are unprotected.
CRON_SECRET=""
